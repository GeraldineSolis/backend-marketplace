# Environment
# development: Más logs, sincronización automática de BD
# production: Mínimos logs, sin sincronización automática
NODE_ENV=development

# Database Configuration
# Usar localhost para desarrollo local, o conexión remota en producción
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=productstore

# Server Configuration
PORT=3001

# JWT Configuration
# Cambiar a una clave fuerte en producción
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# CORS Configuration
# Desarrollo: http://localhost:3000,http://localhost:3001
# Producción: https://tu-dominio-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Node Environment
NODE_ENV=development

